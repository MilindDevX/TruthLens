# TruthLens X - Environment Configuration
# Copy this file to .env and update values for your environment

# ─── Database ───
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/truthlens
DATABASE_URL_SYNC=postgresql+psycopg2://postgres:postgres@localhost:5432/truthlens

# ─── JWT Auth ───
# IMPORTANT: Generate a real secret key with: openssl rand -hex 32
JWT_SECRET_KEY=CHANGE_ME_IN_PRODUCTION_USE_OPENSSL_RAND
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ─── Google OAuth ───
# Configure these when ready:
# GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=your-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/auth/google/callback

# ─── Rate Limiting ───
RATE_LIMIT_PER_MINUTE=60

# ─── File Limits ───
MAX_IMAGE_SIZE_MB=10
MAX_TEXT_WORDS=5000
MAX_TEXT_CHARS=30000

# ─── ML Models ───
ACTIVE_TEXT_MODEL_VERSION=v1.0.0
ACTIVE_IMAGE_MODEL_VERSION=v1.0.0

# ─── Logging ───
LOG_LEVEL=INFO
DEBUG=true

# ─── CORS ───
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]
